NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/matchmaker
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20

JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRATION=7d

PUBLIC_REGISTRATION_ENABLED=false
ADMIN_EMAILS=
REFERRAL_BONUS_TYPE=plus_days
REFERRAL_BONUS_PLUS_DAYS=3
REFERRAL_BONUS_SWIPE_CREDITS=20

# Social auth audience/client IDs
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# Subscriptions (Phase 6)
APPLE_SHARED_SECRET=
GOOGLE_PLAY_PACKAGE_NAME=
# Either raw JSON or base64 encoded JSON service account key
GOOGLE_SERVICE_ACCOUNT_KEY=
SUBSCRIPTIONS_WEBHOOK_SECRET=

# local | bunny
UPLOAD_STRATEGY=local
UPLOAD_DIR=uploads

# required only when UPLOAD_STRATEGY=bunny
BUNNY_STORAGE_ZONE=
BUNNY_ACCESS_KEY=
BUNNY_PULL_ZONE_URL=https://your-pull-zone.b-cdn.net
BUNNY_STORAGE_HOST=storage.bunnycdn.com
